---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Header } from '../components/guaufresh/Header';
import { Footer } from '../components/guaufresh/Footer';
import { WhatsAppButton } from '../components/guaufresh/WhatsAppButton';
import { AuthForm } from '../components/guaufresh/AuthForm';
---

<BaseLayout title="Iniciar Sesión">
  <div class="min-h-screen">
    <Header client:load />
    <main class="py-12 sm:py-16">
      <div class="mx-auto max-w-md px-4 sm:px-6 lg:px-8">
        <AuthForm client:load />
      </div>
    </main>
    <Footer />
    <WhatsAppButton />
  </div>
</BaseLayout>
