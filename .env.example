# Copia este archivo a .env y ajusta los valores.

# URL canónica del sitio (usada por Astro `site`, p. ej. GitHub Pages)
PUBLIC_SITE_URL=https://julian8811.github.io

# Base bajo la que se sirve el sitio. Raíz: /
# GitHub Pages (proyecto): /nombre-del-repo  (p. ej. /guaufresh)
PUBLIC_BASE_PATH=/

# Supabase (opcional en CI: definir como secrets PUBLIC_SUPABASE_*)
PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-aqui

# URL para redirects de OAuth (debe coincidir con el origen en producción)
SITE_URL=http://localhost:4321
